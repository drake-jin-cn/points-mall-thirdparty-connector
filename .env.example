# ============================================================
# points-mall-thirdparty-connector — Environment Variables Reference
# Spring Boot reads these via ${VAR_NAME} in application-{profile}.yml.
# Provide real values via CI/CD secrets or environment injection.
# NEVER commit files with real secrets to Git.
# ============================================================

# ── Application ─────────────────────────────────────────────
PORT=8084
# Activates application-{profile}.yml: dev | test | prod
SPRING_PROFILES_ACTIVE=dev

# ── GitHub OAuth (Required for T012–T013) ───────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:4000/auth/github/callback

# ── AWS (Required for T046 — S3 archive uploads) ────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ── Amazon Product Advertising API (Required for T035) ──────
AMAZON_PA_ACCESS_KEY=
AMAZON_PA_SECRET_KEY=
AMAZON_PA_PARTNER_TAG=
AMAZON_PA_REGION=us-east-1

# ── JWT (Required — must match BFF JWT_SECRET exactly) ──────
JWT_SECRET=

